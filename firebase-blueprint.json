{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A service request from a potential customer",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "service": { "type": "string", "description": "Requested service" },
        "message": { "type": "string", "description": "Additional message" },
        "status": { "type": "string", "enum": ["new", "contacted", "completed", "cancelled"], "description": "Lead status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of creation" }
      },
      "required": ["name", "email", "service", "status", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by Apex Duct Cleaning",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Service title" },
        "description": { "type": "string", "description": "Service description" },
        "price": { "type": "string", "description": "Starting price" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "benefits": { "type": "array", "items": { "type": "string" }, "description": "List of benefits" }
      },
      "required": ["title", "description", "price", "icon", "benefits"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A blog post article",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Post title" },
        "slug": { "type": "string", "description": "URL-friendly slug" },
        "content": { "type": "string", "description": "Markdown/HTML content" },
        "featured_image_url": { "type": "string", "description": "URL of the featured image" },
        "publish_date": { "type": "string", "format": "date-time", "description": "Date of publication" },
        "status": { "type": "string", "enum": ["draft", "published"], "description": "Post status" },
        "category": { "type": "string", "description": "Post category" },
        "excerpt": { "type": "string", "description": "Short summary" },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of creation" }
      },
      "required": ["title", "slug", "content", "status", "created_at"]
    },
    "PageContent": {
      "title": "PageContent",
      "description": "Dynamic content for a website page",
      "type": "object",
      "properties": {
        "hero": { "type": "object", "description": "Hero section content" },
        "stats": { "type": "array", "items": { "type": "object" }, "description": "Statistics section content" },
        "cta": { "type": "object", "description": "Call to action section content" },
        "story": { "type": "object", "description": "Story section content (About page)" },
        "mission": { "type": "object", "description": "Mission section content (About page)" },
        "vision": { "type": "object", "description": "Vision section content (About page)" },
        "team": { "type": "array", "items": { "type": "object" }, "description": "Team members section content (About page)" },
        "info": { "type": "object", "description": "Contact info section content (Contact page)" }
      }
    }
  },
  "firestore": {
    "leads": {
      "schema": "Lead",
      "description": "Collection of service requests"
    },
    "services": {
      "schema": "Service",
      "description": "Collection of services offered"
    },
    "blog_posts": {
      "schema": "BlogPost",
      "description": "Collection of blog post articles"
    },
    "page_content": {
      "schema": "PageContent",
      "description": "Collection of dynamic page content (homepage, about, contact)"
    }
  }
}
